{
  "name": "msrrp-app-dev",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm --workspace backend run dev\" \"npm --workspace frontend run start\"",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run start",
    "typecheck": "npm --workspace backend run typecheck && npm --workspace frontend run typecheck",
    "lint": "npm --workspace frontend run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.1.17",
    "concurrently": "^9.1.0",
    "eslint": "^9.25.0",
    "globals": "^16.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
